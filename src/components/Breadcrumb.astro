---
import type { BreadcrumbItem } from '@/lib/types';

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-2 text-sm">
    <li>
      <a
        href="https://modopag.com.br/?utm_source=blog&utm_medium=breadcrumb&utm_campaign=navegacao"
        class="text-secondary-400 hover:text-primary-600 transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        modoPAG
      </a>
    </li>
    <li class="flex items-center gap-2">
      <svg
        class="w-4 h-4 text-secondary-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"
        />
      </svg>
      <a
        href="/"
        class="text-secondary-400 hover:text-primary-600 transition-colors"
      >
        Blog
      </a>
    </li>
    {items.map((item) => (
      <li class="flex items-center gap-2">
        <svg
          class="w-4 h-4 text-secondary-300"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"
          />
        </svg>
        {item.href ? (
          <a
            href={item.href}
            class="text-secondary-400 hover:text-primary-600 transition-colors"
          >
            {item.label}
          </a>
        ) : (
          <span class="text-secondary-600 font-medium truncate max-w-[200px] sm:max-w-[300px] md:max-w-none">
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
